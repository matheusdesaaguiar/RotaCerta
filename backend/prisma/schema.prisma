generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model address {
  id                                                         String             @id @db.Uuid
  street                                                     String             @db.VarChar(150)
  city                                                       String             @db.VarChar(80)
  state                                                      String             @db.Char(2)
  zip_code                                                   String             @db.VarChar(10)
  Renamedpackage_Renamedpackage_receiver_address_idToaddress Renamedpackage[]   @relation("Renamedpackage_receiver_address_idToaddress")
  Renamedpackage_Renamedpackage_sender_address_idToaddress   Renamedpackage[]   @relation("Renamedpackage_sender_address_idToaddress")
  tracking_updates                                           tracking_updates[]
}

model courier {
  id               String             @id @db.Uuid
  name             String             @db.VarChar(100)
  vehicle_type     String?            @db.VarChar(50)
  delivery_attempt delivery_attempt[]
  tracking_updates tracking_updates[]
}

model customer {
  id                                                  String           @id @db.Uuid
  name                                                String           @db.VarChar(100)
  phone                                               String?          @db.VarChar(20)
  email                                               String?          @unique @db.VarChar(150)
  password                                            String
  notification                                        notification[]
  Renamedpackage_Renamedpackage_receiver_idTocustomer Renamedpackage[] @relation("Renamedpackage_receiver_idTocustomer")
  Renamedpackage_Renamedpackage_sender_idTocustomer   Renamedpackage[] @relation("Renamedpackage_sender_idTocustomer")
}

model delivery_attempt {
  id             String                  @id @db.Uuid
  package_id     String                  @db.Uuid
  courier_id     String                  @db.Uuid
  attempt_number Int
  status         delivery_attempt_status
  notes          String?
  attempted_at   DateTime?               @default(now()) @db.Timestamp(6)
  courier        courier                 @relation(fields: [courier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Renamedpackage Renamedpackage          @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model distribution_center {
  id               String             @id @db.Uuid
  name             String             @db.VarChar(100)
  city             String?            @db.VarChar(80)
  state            String?            @db.Char(2)
  tracking_updates tracking_updates[]
}

model notification {
  id             String              @id @db.Uuid
  package_id     String              @db.Uuid
  customer_id    String              @db.Uuid
  message        String
  sent_at        DateTime?           @default(now()) @db.Timestamp(6)
  status         notification_status
  customer       customer            @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Renamedpackage Renamedpackage      @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has been renamed to 'Renamedpackage' during introspection, because the original name 'package' is reserved.
model Renamedpackage {
  id                                                  String             @id @db.Uuid
  tracking_code                                       String             @unique @db.VarChar(20)
  sender_id                                           String             @db.Uuid
  receiver_id                                         String             @db.Uuid
  current_status                                      package_status
  current_location                                    String?            @db.VarChar(100)
  sender_address_id                                   String?            @db.Uuid
  receiver_address_id                                 String?            @db.Uuid
  is_canceled                                         Boolean?           @default(false)
  created_at                                          DateTime?          @default(now()) @db.Timestamp(6)
  delivery_attempt                                    delivery_attempt[]
  notification                                        notification[]
  address_Renamedpackage_receiver_address_idToaddress address?           @relation("Renamedpackage_receiver_address_idToaddress", fields: [receiver_address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer_Renamedpackage_receiver_idTocustomer       customer           @relation("Renamedpackage_receiver_idTocustomer", fields: [receiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address_Renamedpackage_sender_address_idToaddress   address?           @relation("Renamedpackage_sender_address_idToaddress", fields: [sender_address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer_Renamedpackage_sender_idTocustomer         customer           @relation("Renamedpackage_sender_idTocustomer", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  package_item                                        package_item[]
  tracking_updates                                    tracking_updates[]

  @@map("package")
}

model package_item {
  id             String         @id @db.Uuid
  package_id     String         @db.Uuid
  description    String         @db.VarChar(150)
  weight         Float?
  Renamedpackage Renamedpackage @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model tracking_updates {
  id                  String               @id @db.Uuid
  package_id          String               @db.Uuid
  status              package_status
  location_id         String?              @db.Uuid
  courier_id          String?              @db.Uuid
  center_id           String?              @db.Uuid
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  distribution_center distribution_center? @relation(fields: [center_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courier             courier?             @relation(fields: [courier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address             address?             @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Renamedpackage      Renamedpackage       @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum delivery_attempt_status {
  success
  failed
  recipient_absent
  address_not_found
  refused
}

enum notification_status {
  pending
  sending
  failed
}

enum package_status {
  posted
  in_transit
  out_for_delivery
  delivered
  canceled
}
